import numpy as np

class pursuer:
    def __init__(self,initPos,speed,index):
        self.index = index
        self.position = initPos
        self.speed = speed
        self.status = 0
        self.self = 0

    def updatePos(self,position):
        print(position)
        position = np.array(position).flatten()[:1]
        
        try:
            sz_input = np.shape(position[self.index])
        except:
            sz_input = np.shape(position[0][self.index])
        sz_output = np.shape(self.position)
        
        if (sz_input != sz_output):
            self.position = position.T

        else:
            self.position = position

    def return_velocity(self,evader,B,tolerance):
        alpha = evader.speed/self.speed
        xe = evader.position
        xp = self.position
        xc = (xe - alpha**2 * xp)/(1 - alpha**2)
        Rc = np.linalg.norm(xc)
        rc = (alpha/(1-alpha**2))*np.linalg.norm(xp-xe)

        if B>=0:
            if abs(np.linalg.norm(self.position - evader.position))>tolerance:
                gradV = (alpha**2/(1-alpha**2))*(-xc/Rc+(1/(1-alpha**2))*((xp-xe)/rc))

                rhop = np.linalg.norm(gradV)
                velocity = (self.speed/rhop)*gradV

            else:
                velocity = np.zeros((1,2))

        elif (B<0):
            if abs(np.linalg.norm(xe))>1e-2:
                gradV = xp/np.linalg.norm(xp)
                rhop = np.linalg.norm(gradV)
                velocity = (-self.speed/rhop)*gradV
            else:
                velocity = np.zeros((1,2))

        return velocity
